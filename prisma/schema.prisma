generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id            String   @id @default(uuid())
  marketxId     String?  @unique // The corresponding order ID on MarketX
  userId        String   // The MarketX User ID who made the purchase
  sellerId      String   // The MarketX Seller ID
  productId     String
  productName   String
  amount        Float
  currency      String   @default("NGN")
  
  // Status can be: PENDING, PAID, SHIPPED, DELIVERED, DISPUTED
  status        String   @default("PENDING")
  trackingNo    String?
  disputeReason String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}