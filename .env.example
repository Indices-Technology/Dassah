# ─────────────────────────────────────────────────────────────────────────────
# Dassah API + Worker — Environment Variables
# Copy the relevant section into Railway's "Variables" tab for each service.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared (both API and Worker need these) ───────────────────────────────────

NODE_ENV=production
PORT=4000

# Redis — use the Upstash *connection string* URL (NOT the REST URL).
# Find it in Upstash dashboard → your database → Connect → ioredis
# Format: rediss://default:<password>@<host>:<port>
REDIS_URL=rediss://default:XXXXXXXXXXXX@smart-dog-00000.upstash.io:6380

# JWT — must be the EXACT same secret that MarketX signs its tokens with
JWT_SECRET=same_value_as_marketx_nuxt_jwt_secret

# MarketX internal communication
MARKETX_API_URL=https://your-marketx-app.vercel.app
MARKETX_API_KEY=dassah_internal_api_key_change_this

# ── API only ──────────────────────────────────────────────────────────────────

SESSION_TTL_SECONDS=900

# Default AI provider (used when user has no personal API key configured)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: enable OpenAI fallback
# OPENAI_API_KEY=sk-proj-...

# Payment providers (used by the payment skill)
PAYSTACK_SECRET_KEY=sk_live_...
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...

# ── Worker only ───────────────────────────────────────────────────────────────

# Same as above — worker needs MarketX API access to create orders
# MARKETX_API_URL=https://your-marketx-app.vercel.app
# MARKETX_API_KEY=dassah_internal_api_key_change_this

# ── Dassah UI (Nuxt on Vercel) ────────────────────────────────────────────────

# JWT — same secret
# JWT_SECRET=same_value_as_marketx

# The Railway URL for your API service
# NUXT_PUBLIC_SOCKET_URL=https://dassah-api.up.railway.app
# NUXT_PUBLIC_API_URL=https://dassah-api.up.railway.app

# Where the Dassah UI redirects for MarketX auth
# MARKETX_BASE_URL=https://your-marketx-app.vercel.app
# NUXT_PUBLIC_BASE_URL=https://your-dassah-ui.vercel.app

# ── MarketX Nuxt (already deployed on Vercel) ─────────────────────────────────
# Add this one env var to your existing MarketX Vercel project:
# NUXT_PUBLIC_DASSA_SOCKET_URL=https://dassah-api.up.railway.app
